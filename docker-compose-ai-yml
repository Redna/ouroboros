services:
  nginx-proxy:
    image: 'jc21/nginx-proxy-manager:latest'
    container_name: nginx-proxy
    restart: unless-stopped
    ports:
      - '80:80'
      - '81:81'
      - '443:443'
    volumes:
      - ./nginx_data:/data
      - ./nginx_letsencrypt:/etc/letsencrypt

  dashboard:
    image: linuxserver/heimdall:latest
    container_name: heimdall
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Berlin
    volumes:
      - ./heimdall_data:/config
    ports:
      - "8080:80"

  vllm:
    image: vllm/vllm-openai-rocm:latest
    container_name: vllm_server_v2
    restart: unless-stopped
    devices:
      - /dev/kfd:/dev/kfd
      - /dev/dri:/dev/dri
    group_add:
      - video
    cap_add:
      - SYS_PTRACE
    security_opt:
      - seccomp=unconfined
    ipc: host
    volumes:
      - ~/.cache/huggingface:/root/.cache/huggingface
    ports:
      - "8000:8000"
    environment:
      - HSA_OVERRIDE_GFX_VERSION=11.0.0
      - HIP_FORCE_DEV_KERNARG=1
      - TORCH_BLAS_PREFER_HIPBLASLT=1
      - VLLM_ROCM_USE_AITER=0
      - VLLM_USE_TRITON_AWQ=1
    command:
      - "--model"
      - "cyankiwi/Ministral-3-14B-Instruct-2512-AWQ-4bit"
      - "--quantization"
      - "compressed-tensors"
      - "--kv-cache-dtype"
      - "fp8"
      - "--max-model-len"
      - "131072"
      - "--gpu-memory-utilization"
      - "0.9"
      - "--dtype"
      - "float16"
      - "--enforce-eager"
      - "--limit-mm-per-prompt"
      - '{"image":0}'
      - "--enable-auto-tool-choice"
      - "--tool-call-parser"
      - "mistral"
